# CanvasX Environment Configuration
# Copy this file to .env and fill in your values

# NVIDIA / MiniMax M2.5 API key
# Get yours at: https://integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# PostgreSQL connection
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=canvasnew
DB_USER=canvasnew
DB_PASS=your-secure-password-here

# App base URL (no trailing slash)
CANVAS_BASE_URL=http://localhost:8080

# Environment: development | production
APP_ENV=development
